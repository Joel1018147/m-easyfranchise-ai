# ─────────────────────────────────────────────
#  M-EasyFranchise AI — Environment Variables
# ─────────────────────────────────────────────

# App
PORT=3002
NODE_ENV=development
APP_URL=http://localhost:3002

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/m_easyfranchise

# Auth
JWT_SECRET=change-this-to-a-long-random-string-min-64-chars

# AI (Groq - free at console.groq.com)
GROQ_API_KEY=gsk_...

# MODUS Ecosystem Integration
MODUS_EASYDO_URL=http://localhost:3000
MODUS_SMAI_URL=http://localhost:3001
MODUS_EASYMEMBERS_URL=http://localhost:3003
MODUS_INTERNAL_SECRET=modus-internal-secret-change-this

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
